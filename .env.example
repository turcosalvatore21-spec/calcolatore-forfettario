# Copia questo file in .env.local e inserisci i valori del tuo progetto Supabase
# (Dashboard Supabase → Project Settings → API)
VITE_SUPABASE_URL=https://tuo-progetto.supabase.co
VITE_SUPABASE_ANON_KEY=la-tua-publishable-key

# Lemon Squeezy per il piano Pro. In SVILUPPO (vite dev) se le ometti si usano
# i valori di default di test nel codice. In PRODUZIONE (build su Vercel) i
# default NON valgono: queste variabili DEVONO essere impostate, altrimenti il
# checkout risulta non configurato. È così che test e live si distinguono solo
# dalla configurazione su Vercel.
#
# Sottodominio dello store:
# VITE_LEMONSQUEEZY_STORE=strataitalia
#
# UUID di checkout (vanno nell'URL /checkout/buy/<uuid>): si copiano da
# Lemon Squeezy → Products → Share. NON sono i numeri qui sotto.
# VITE_LEMONSQUEEZY_CHECKOUT_MONTHLY=1e79cbcc-5be2-4823-85d9-3a88a7b59b9e
# VITE_LEMONSQUEEZY_CHECKOUT_ANNUAL=5f2cdc12-54f3-4a44-9c62-ee732a81d08e
#
# Variant id NUMERICI dell'API: usati SOLO dal webhook (stesse variabili
# lette lì via process.env) per dedurre il piano dall'evento.
# VITE_LEMONSQUEEZY_VARIANT_MONTHLY=1932382
# VITE_LEMONSQUEEZY_VARIANT_ANNUAL=1932369

# --- Solo lato server (impostare su Vercel, NON esposte al client) ---
# Signing secret del webhook (Lemon Squeezy → Settings → Webhooks)
# LEMONSQUEEZY_WEBHOOK_SECRET=...
# Service role key Supabase, usata dal webhook per scrivere lo stato Pro
# SUPABASE_SERVICE_ROLE_KEY=...
# API key Lemon Squeezy (Settings → API), usata dal portale cliente
# LEMONSQUEEZY_API_KEY=...
